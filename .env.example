# ── Database ──────────────────────────────────────────────────────────────────
# Local: matches docker-compose.yml defaults
# Serverless: use Neon pooled connection string (postgres://...?sslmode=require)
DATABASE_URL="postgresql://tenantkit:tenantkit_dev@localhost:5432/tenantkit_dev"

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-byte-random-secret"
# Canonical URL for this deployment (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Storage (local adapter — no config needed locally) ───────────────────────
# LOCAL_STORAGE_DIR="./storage"   # resolved by LocalDiskAdapter; defaults to ./storage
# Serverless: uncomment and fill when using Vercel Blob or R2
# BLOB_READ_WRITE_TOKEN=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""
# R2_ENDPOINT=""

# ── Notifications (console adapter used locally — no config needed) ───────────
# Serverless: fill when real email/SMS adapters are wired
# RESEND_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ── PayMongo (module: gateway_payments — not active in MVP) ──────────────────
# PAYMONGO_PUBLIC_KEY=""
# PAYMONGO_SECRET_KEY=""
# PAYMONGO_WEBHOOK_SECRET=""
